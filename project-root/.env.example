# AWS credentials for boto3
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_DEFAULT_REGION=us-east-1

# Raw S3 ingestion target
RAW_S3_BUCKET=your-s3-bucket-name
RAW_S3_REGION=us-east-1
RAW_S3_PREFIX=raw

# Optional for MinIO / non-AWS S3 only
# RAW_S3_ENDPOINT_URL=http://localhost:9000
# RAW_S3_ACCESS_KEY_ID=minioadmin
# RAW_S3_SECRET_ACCESS_KEY=minioadmin

# Optional tuning
# RAW_S3_BATCH_SIZE=100
# RAW_S3_FLUSH_INTERVAL=60

# Optional source credential
# GITHUB_TOKEN=your-github-token
