# Kafka
BOOTSTRAP_SERVERS=localhost:9092

# Optional source credential
GITHUB_TOKEN=

# Raw S3 / MinIO ingestion target
RAW_S3_BUCKET=techtrends-raw
RAW_S3_REGION=us-east-1
RAW_S3_PREFIX=raw

# MinIO / S3-compatible local storage
RAW_S3_ENDPOINT_URL=http://localhost:9000
RAW_S3_ACCESS_KEY_ID=minioadmin
RAW_S3_SECRET_ACCESS_KEY=minioadmin

# Optional tuning
RAW_S3_BATCH_SIZE=100
RAW_S3_FLUSH_INTERVAL=60

# Output paths (leave unset to use repo defaults)
# PROCESSED_DIR=
# FEATURE_STORE_DIR=
# ML_MODELS_DIR=

# PostgreSQL persistence. Raw generated files stay local; DB persistence starts
# from normalized processed records and derived artifacts.
DATABASE_URL=postgresql+psycopg2://postgres:postgres@127.0.0.1:5433/techtrends
ENABLE_DB_PERSISTENCE=true
STORE_NORMALIZED_RECORDS=true
CLEAN_DB_LATEST_ONLY=false
DB_BATCH_SIZE=1000

# Logging
LOG_LEVEL=INFO

# Local ML training controls
ML_RANDOM_FOREST_ESTIMATORS=100
ML_TRAIN_XGBOOST=false
ML_TRAIN_PROPHET=false
